// --------------------------------------------------------
void renderMap(int px, int py) {
    int rows = (map_floor + 2) * 10;
    int cols = (map_floor + 2) * 10;
    int y, x;

    system("cls");

    setColor(11);
    printf("\n ========================================================================\n");
    printf("   전설의 전사 %s | HP: %d / %d | MP: %d / %d\n", player_name,
        player_hp, player_max_hp, player_mp, player_max_mp);
    printf("   상태: %s\n", message_log);
    printf(" ========================================================================\n");

    if (map_floor == 3) rows = 40;
    if (map_floor == 4) { rows = 7; cols = 15; }

    for (y = 0; y < rows; y++) {
        printf("  ");
        for (x = 0; x < cols; x++) {
            if (x == px && y == py) {
                setColor(10);
                printf("@ ");
            }
            else {
                switch (map[y][x]) {
                case 0:
                    printf("  "); break;
                case 1:
                    setColor(8);
                    printf("##"); break;
                case 2:
                    setColor(15);
                    printf("S "); break;
                case 3:
                    setColor(13);
                    printf(player_has_key ? "O " : "X "); break;
                case 4:
                    setColor(14);
                    printf("+ "); break;
                case 5:
                    setColor(12);
                    printf("^^"); break;
                case 6:
                    setColor(7);
                    printf("U "); break;
                case 7:
                    setColor(12);
                    printf("B "); break;
                case 8:
                    setColor(12);
                    printf("%%%%"); break;
                case 9:
                    setColor(13);
                    printf("%%%%"); break;
                default:
                    printf("  "); break;
                }
            }
        }
        printf("\n");
    }

    setColor(15);
    printf("\n  조작: [W]위 [A]왼쪽 [S]아래 [D]오른쪽  [Q]종료\n");
    fflush(stdout);
}

