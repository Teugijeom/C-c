    int k = 0;
    int i, j;
    boss_room_key++;

    for (i = 0; i < 50 && k == 0; i++) {
        for (j = 0; j < 50 && k == 0; j++) {
            if (map[i][j] == 8) {
                map[i][j] = 9;
                k++;
            }
        }
    }
}

