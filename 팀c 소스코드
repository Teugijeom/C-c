// --------------------------------------------------------
// 보물상자 무기 드랍 및 인벤토리 추가
// --------------------------------------------------------
void openTreasureChest(void) {
    if (inven_count >= MAX_INVEN) {
        system("cls");
        setColor(12);
        printf("\n\n\n\t🚫 인벤토리가 가득 차서 더 이상 무기를 획득할 수 없습니다!\n");
        printf("\t아무 키나 누르면 모험을 계속합니다.");
        setColor(15);
        _getch();
        return;
    }

    int dice = rand() % 100 + 1; // 1 ~ 100
    Weapon found;

    // 등급별 드랍 확률과 무기 세팅
    if (dice <= 55) { // 55% 일반 등급
        int sub_dice = rand() % 2;
        if (sub_dice == 0) {
            strcpy(found.name, "강철 장검 (일반)");
            found.bonus_atk = 4; found.crit_chance = 8; found.hit_rate = 5;
        }
        else {
            strcpy(found.name, "무거운 도끼 (일반)");
            found.bonus_atk = 7; found.crit_chance = 5; found.hit_rate = -5;
        }
    }
    else if (dice <= 85) { // 30% 희귀 등급
        int sub_dice = rand() % 2;
        if (sub_dice == 0) {
            strcpy(found.name, "암살자의 단검 (희귀)");
            found.bonus_atk = 6; found.crit_chance = 25; found.hit_rate = 10;
        }
        else {
            strcpy(found.name, "성전사의 메이스 (희귀)");
            found.bonus_atk = 11; found.crit_chance = 12; found.hit_rate = 0;
        }
    }
    else if (dice <= 97) { // 12% 영웅 등급
        strcpy(found.name, "드래곤 슬레이어 (영웅)");
        found.bonus_atk = 18; found.crit_chance = 20; found.hit_rate = 5;
    }
    else { // 3% 전설 등급
        strcpy(found.name, "🌟심연의 집행자🌟 (전설)");
        found.bonus_atk = 28; found.crit_chance = 35; found.hit_rate = 15;
    }

    // 인벤토리에 추가
    inventory[inven_count] = found;
    inven_count++;

    system("cls");
    setColor(14);
    printf("\n\n\n\t🎁 보물상자를 열었습니다!\n");
    printf("\t----------------------------------------------------\n");
    printf("\t획득 무기: %s\n", found.name);
    printf("\t추가 공격력: +%d\n", found.bonus_atk);
    printf("\t치명타 확률: %d%%\n", found.crit_chance);
    printf("\t명중률 보정: %+d%%\n", found.hit_rate);
    printf("\t----------------------------------------------------\n");
    printf("\t인벤토리에 추가되었습니다. (현재 %d/%d개)\n", inven_count, MAX_INVEN);
    printf("\t아무 키나 누르면 모험을 계속합니다.");
    setColor(15);
    _getch();
}

// --------------------------------------------------------
// 인벤토리 표시 및 무기 장착 기능
// --------------------------------------------------------
void showInventory(void) {
    system("cls");
    setColor(14);
    printf("\n  ==================== 인벤토리 ====================\n");
    printf("  [현재 장착 무기] %s (공격력+%d, 치명타%d%%, 명중률%+d%%)\n",
        current_weapon.name, current_weapon.bonus_atk, current_weapon.crit_chance, current_weapon.hit_rate);
    printf("  --------------------------------------------------\n");

    for (int i = 0; i < inven_count; i++) {
        printf("   %d. %s (공격력+%d, 치명타%d%%, 명중률%+d%%)\n",
            i + 1, inventory[i].name, inventory[i].bonus_atk, inventory[i].crit_chance, inventory[i].hit_rate);
    }
    printf("   0. 닫기\n");
    printf("  ==================================================\n");
    printf("  장착할 무기 번호를 선택하세요 (1~%d): ", inven_count);
    fflush(stdout);

    int input = _getch();
    if (input >= '1' && input < '1' + inven_count) {
        int choice = input - '0' - 1;
        current_weapon = inventory[choice];
        strcpy(message_log, "무기를 변경했습니다.");
    }
}

// --------------------------------------------------------
// 전체 맵 렌더링 (시야 반영: 플레이어 기준 3x3 영역만 출력)
// --------------------------------------------------------
void renderMap(int px, int py) {
    int rows = (map_floor + 2) * 10;
    int cols = (map_floor + 2) * 10;
    int y, x;

    system("cls");

    setColor(11);
    printf("\n ========================================================================\n");
    printf("   전설의 전사 %s | HP: %d / %d | MP: %d / %d\n", player_name,
        player_hp, player_max_hp, player_mp, player_max_mp);
    printf("   장착 무기: %s (공격력+%d, 크리%d%%, 명중%+d%%)\n", current_weapon.name,
        current_weapon.bonus_atk, current_weapon.crit_chance, current_weapon.hit_rate);
    printf("   상태: %s\n", message_log);
    printf(" ========================================================================\n");

    if (map_floor == 3) rows = 40;
    if (map_floor == 4) { rows = 7; cols = 15; }

    for (y = 0; y < rows; y++) {
        printf("  ");
        for (x = 0; x < cols; x++) {
            // 시야 제한: 플레이어의 X, Y 좌표 기준 거리차가 5 이하인 영역만 공개
            if (abs(x - px) <= 5 && abs(y - py) <= 5) {
                if (x == px && y == py) {
                    setColor(10);
                    printf("@ ");
                }
                else {
                    switch (map[y][x]) {
                    case 0:
                        printf("  "); break;
                    case 1:
                        setColor(8);
                        printf("##"); break;
                    case 2:
                        setColor(15);
                        printf("S "); break;
                    case 3:
                        setColor(13);
                        printf(player_has_key ? "O " : "X "); break;
                    case 4:
                        setColor(14);
                        printf("+ "); break;
                    case 5:
                        setColor(12);
                        printf("^^"); break;
                    case 6:
                        setColor(7);
                        printf("U "); break;
                    case 7:
                        setColor(12);
                        printf("B "); break;
                    case 8:
                        setColor(12);
                        printf("%%%%"); break;
                    case 9:
                        setColor(13);
                        printf("%%%%"); break;
                    case 10: // 보물상자 타일
                        setColor(11);
                        printf("T "); break;
                    default:
                        printf("  "); break;
                    }
                }
            }
            else {
                // 시야 영역 밖은 어둠 처리
                setColor(8);
                printf("??");
            }
        }
        printf("\n");
    }

    setColor(15);
    printf("\n  조작: [W]위 [A]왼쪽 [S]아래 [D]오른쪽 | [I]인벤토리  [Q]종료\n");
    fflush(stdout);
}

