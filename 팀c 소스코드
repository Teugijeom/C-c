            }
            printf("  >> %s\n", b_log);
            fflush(stdout);
            Sleep(800);
        }
        else {
            continue;
        }

        if (e_hp <= 0) break;

        // 적 반격
        if (enemy_type == 6) {
            enemy_dmg = rand() % 5 + 8;
            if (is_defending) enemy_dmg /= 2;
        }
        else if (enemy_type == 7) {
            if (map_floor == 1) {
                enemy_dmg = rand() % 11 + 20;
            }
            else if (map_floor == 2) {
                enemy_dmg = rand() % 11 + 25;
                if (is_defending) enemy_dmg /= 2;
            }
            else if (map_floor == 3) {
                nm_immune_next = (nm_turn % 3 == 0) ? 1 : 0;

                if (nm_immune_next) {
                    if (player_dmg > 0) {
                        e_hp += player_dmg;
                        printf("  >> 나이트메어: 겨우 이 정도인가...\n");
                        printf("  >> 나이트메어가 HP를 회복했다.\n");
                        fflush(stdout);
                        Sleep(800);
                    }
                    enemy_dmg = 16;
                    if (is_defending) enemy_dmg /= 2;
                }
                else if (nm_copy_skill) {
                    nm_copy_skill = 0;
                    if (player_mp >= 10) {
                        player_mp -= 10;
                        enemy_dmg = rand() % 11 + 15;
                        printf("  >> 나이트메어가 %s의 MP를 흡수했다. MP -10!\n", player_name);
                        fflush(stdout);
                        Sleep(800);
                    }
                    else {
                        enemy_dmg = 16;
                        fflush(stdout);
                        Sleep(800);
                    }
                    if (is_defending) enemy_dmg /= 2;
                }
                else {
                    nm_copy_skill = 0;
                    enemy_dmg = 16;
                    if (is_defending) enemy_dmg /= 2;
                }
            }
        }
        player_hp -= enemy_dmg;
        sprintf(b_log, "%s의 반격! %s에게 %d의 피해!", e_name, player_name, enemy_dmg);
        Sleep(800);
    }

    system("cls");
    if (player_hp <= 0) return -1;
    return 1;
}

